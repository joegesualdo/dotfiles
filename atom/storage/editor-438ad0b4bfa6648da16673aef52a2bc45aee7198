{"mode":"editor","version":1,"windowDimensions":{"x":143,"y":23,"width":1024,"height":773,"maximized":false},"grammars":{"deserializer":"GrammarRegistry","grammarOverridesByPath":{}},"project":{"paths":["/Users/joegesualdo/Downloads/tetra"],"buffers":[{"text":";---------------------------------------------------------------------------------------------------------\r\n; Randomizer -- Generates a random byte from the double word seed pointed\r\n; to by SI, stores it in AL, and updates the seed.\r\n; - Input: \r\n;   SI: Adress to double word seed.\r\n; - Output:\r\n;   AL: Generated random byte.\r\n;---------------------------------------------------------------------------------------------------------\r\nRandomizer:\n    push ebp\r\n    push ebx\r\n    \r\n    mov  eax, dword [SI]    ; Put the seed into EAX. The random byte will be generated entirely from this dword.\r\n    ; First randomizing process:\r\n    mov  ebp, 0A5F784CDh    ; Assign an arbitrarily chosen dword to EBP for multiplication.\r\n    mul  ebp                ; Multiply the seed with the EBP value.\r\n    ror  eax, 17            ; Rotate EAX 17 steps to the right. 17 is just any uneven number.\r\n    xor  eax, 0F94D13DDh    ; XOR EAX with another arbitrarily chosen dword.\r\n    ; The following second randomizing process is similar to the first one, the only difference being other arbitrary numbers.\r\n    mov  ebp, 0C8456745h\r\n    mul  eax\r\n    rol  eax, 23\r\n    xor  eax, 07FA5CC89h\r\n    ; Randomizing processes n ow completed, update seed and finish the random number:\r\n    mov  dword [SI], eax\r\n    shr  eax, 12\r\n    \r\n    pop ebx\r\n    pop ebp\r\n    \r\n    ret\r\n;END of Randomizer    \r\n\n\t\r;---------------------------------------------------------------------------------------------------------\r\n; DrawFullRect -- Draws a filled rectangle on the screen with the specified colour at the assigned coordinates.\r\n; The X- and Y-coordinates specify the top left of the rectangle, which is from where \r\n; the actual drawing will start.\r\n; Assumed screen width: 320.\r\n; - Input: \r\n;   DI: X-coordinate on screen.\r\n;   AX: Y-coordinate on screen.\r\n;   CX: Width of filled rectangle.\r\n;   BX: Height of filled rectangle.\r\n;   DL: Colour value.\r\n; - Output: Filled rectangle on screen at assigned coordinates (screen adress in ES).\r\n;---------------------------------------------------------------------------------------------------------\r\nDrawFullRect:\r\n    push bp\r\n    push dx\r\n\t; First step: convert the given X- and Y-coordinates to the correct screen address in DI. Correct screen address = 320*y+x.\r\n    mov  bp, ax\t\t\t\t; Duplicate Y-coordinate.\r\n    shl  ax, 8\t\t\t\t; Multiply with 256 to get 256*y.\r\n    shl  bp, 6\t\t\t\t; Multiply with 64 to get 64*y.\r\n    add  di, ax\t\t\t\t; Together the result will be 256*y ...\r\n    add  di, bp\t\t\t\t; ... + 64*y = 320*y. Content of DI is now 320*y+x.\r\n\t; Set up AX, DX and BP to appropriate values for the draw loop.\r\n    mov  bp, cx\t\t\t\t; Duplicate the rectangle width to BP\r\n    shr  bp, 1\t\t\t\t; and halve it to get the number of words per line.\r\n    mov  al, dl\t\t\t\t; Move the colour value to AL\r\n    mov  ah, al\t\t\t\t; and also copy it to AH (Now AX contains only the wanted colour).\r\n    mov  dx, 320\t\t\t; Put screen width + 1 in DX\r\n    sub  dx, cx\t\t\t\t; and subtract the rectangle width.\r\n\t; All registers set: proceed to draw the rectangle:\r\n_DrawLoop:\r\n    mov  cx, bp\t\t\t\t; Update CX with the amount of words  to copy.\r\n    rep  stosw\t\t\t\t; Copy colour values in AX to the screen.\r\n    add  di, dx\t\t\t\t; Jump to the first pixel of the next line.\r\n    dec  bx\t\t\t\t\t; One line now completed.\r\n    jnz  _DrawLoop\t\t\t; Loop if all lines are not drawn.\r\n    \r\n    pop  dx\r\n    pop  bp\r\n    \r\n    ret\r\n; End of DrawFullRect\r\n\r\n\n\r\n;-----------------------------------------------------------------------------------------------\r\n; DrawSprite -- Draws a sprite on the screen at the assigned coordinates.\r\n; The sprite is assumed to be stored as a linear sequence of bytes (1 per pixel)\r\n; in memory. Exception: the first word must be the sprite width, and the second\r\n; word the height. Directly after this comes the pixel byte sequence.\r\n; Assumed screen width: 320.\r\n; - Input: \r\n;   DI: X-coordinate on screen.\r\n;   AX: Y-coordinate on screen.\r\n;   SI: Adress to the first byte of the sprite data.\r\n; - Output: Sprite on screen at assigned coordinates (screen adress in ES).\r\n;-----------------------------------------------------------------------------------------------\r\nDrawSprite:\r\n\t; Save the affected (but not obvious) registers to the stack.\r\n    push bx\r\n    push cx\r\n    push dx\r\n\n\t; First step: convert the given X- and Y-coordinates to the correct screen address in DI. Correct screen address = 320*y+x.\r\n    mov  bx, ax\t\t\t\t; Duplicate AX enable the double shift operations.\r\n    shl  ax, 8\t\t\t\t; Multiply Y-coordinate by 256.\r\n    shl  bx, 6\t\t\t\t; Multiply the same value with 64. 256*y+64*y = 320*y\r\n    add  di, ax\t\t\t\t; Add to DI (which, as we know, already contains X) 256*y.\r\n    add  di, bx\t\t\t\t; Finally, add 64*y. The resulting DI now contains 320*y+x.\r\n\t; The following code prepares for the draw loop by using the values in first two words of the sprite (see explanation above).\r\n    mov  ax, word [si]\t\t; Move the sprite width to AX.\r\n    mov  dx, 320\t\t\t; Move the screen width to DX and...\r\n    sub  dx, ax\t\t\t\t; ... subtract the sprite width. \r\n    add  si, 2\t\t\t\t; Make SI point to the next word in the sprite array.\r\n    mov  bx, word [si]\t\t; This is the sprite height which we assign to BX.\r\n    add  si, 2\t\t\t\t; Add 2 to SI again, so that it now points to the first pixel of the sprite.\r\n\tshr  ax, 1\t\t\t\t; By dividing the sprite width by 2, AX now contains the  number of words per line.\r\n\t; The draw loop where the actual drawing of the sprite occurs:\r\nDrawLoop:\r\n    mov  cx, ax\t\t\t\t; Copy the number of words to move to CX (which will be counted down by rep movsw).\r\n    rep  movsw\t\t\t\t; Move CX number of words from DS:SI to ES:DI.\r\n    add  di, dx\t\t\t\t; Move the pixel pointer to the first pixel of the next line.\r\n    dec  bx\t\t\t\t\t; One line completed, one step closer to completion.\r\n    jnz  DrawLoop\t\t\t; If there are still lines left to draw (BX = 0), repeat the draw loop.\r\n    ; Copy the saved registers back in the appropriate sequence.\n\r\n    pop  dx\r\n    pop  cx\r\n    pop  bx\r\n    \r\n    ret\t\t\t\t\t\t; Sprite drawn to screen completely, return.\r\n; END of DrawSprite\r\n\n\r\n;----------------------------------------------------\r\n; CentiSec -- Returns the number of centiseconds (1/100 s)  passed since midnight.\r\n; - Input: \r\n;   No input required.\r\n; - Output:\r\n;   EBX: Number of centiseconds since midnight.\r\n;----------------------------------------------------\r\nCentiSec:\r\n    push eax\r\n    push esi\r\n    push cx\r\n    push dx\r\n    push bp\r\n    \r\n    mov  ah, 2Ch            ; Set things up to retrieve the time passed since midnight.   \r\n    int  21h                ; Get the time: CH = hours, CL = minutes, DH = seconds, DL = centiseconds.\r\n    mov  bp, dx\r\n    \r\n    ; Hour conversion:\r\n    xor  eax, eax           ; Set EAX to zero.\r\n    xor  ebx, ebx           ; Set EBX to zero.   \r\n    mov  al, ch             ; Hours to AL for multiplication.\r\n    mov  esi, 360000\r\n    mul  esi                ; Convert hours to centiseconds by multiplying by 60*60*100 = 360 000.\r\n    mov  ebx, eax           ; Copy product to EBX.\r\n    \r\n    ; Minute conversion:\r\n    xor  eax, eax           ; Zero out EAX for next multiplication. \r\n    mov  al, cl             ; Minutes to AL for multiplication.\r\n    mov  esi, 6000\r\n    mul  esi                ; Convert minutes to centiseconds by multiplying by 60*100 = 6000.\r\n    add  ebx, eax           ; Add product to EBX. \r\n    \r\n    ; Second conversion:\r\n    xor  eax, eax           ; Zero out EAX for the last multiplication.\r\n    mov  ax, bp             ; Seconds to AL for multiplication.\r\n    shr  ax, 8\r\n    mov  esi, 100\r\n    mul  esi                ; Convert seconds to centiseconds by multiplying by 100.\r\n    add  ebx, eax           ; Add product to EBX.\r\n    \r\n    ; Addition of single centiseconds:\r\n    and  bp, 00FFh\r\n    add  bx, bp             ; Finally, add the number of measured single centiseconds to BL.\r\n    \r\n    pop  bp\r\n    pop  dx\r\n    pop  cx\r\n    pop  esi\r\n    pop  eax\r\n    \r\n    ret                     ; We're finished, get out!\r\n; END of CentiSec\r\n\n\r\n;---------------------------------------------------------------------------------------------------------\r\n; DrawRect -- Draws a  rectangle on the screen with the specified colour at the assigned coordinates.\r\n; The X- and Y-coordinates specify the top left of the rectangle, which is from where \r\n; the actual drawing will start.\r\n; Assumed screen width: 320.\r\n; - Input: \r\n;   DI: X-coordinate on screen.\r\n;   AX: Y-coordinate on screen.\r\n;   CX: Width of rectangle.\r\n;   BX: Height of rectangle.\r\n;   DL: Colour value.\r\n; - Output: Rectangle on screen at assigned coordinates (segment of video address in ES).\r\n;---------------------------------------------------------------------------------------------------------\r\nDrawRect:\r\n    push bp\r\n    push dx\r\n\n    ; Convert the X- and Y-coordinates to the correct address in DI. The resulting value in DI must be 320*y+x.\r\n    mov  bp, ax\t\t\t\t; Duplicate the Y-coordinate.\r\n    shl  ax, 8\t\t\t\t; AX = 256*y\r\n    shl  bp, 6\t\t\t\t; BP = 64*y\r\n    add  di, ax\t\t\t\t; By adding 256*y\r\n    add  di, bp\t\t\t\t; and 64*y, DI now contains 320*y+x.\r\n    ; Prepare registers and finally draw the first horizontal line:\r\n    mov  bp, cx\t\t\t\t; Save the byte number in BP because we need it later, for the other horizontal line.\t\t\t\t\r\n    mov  al, dl\t\t\t\t; Copy colour value to AL\r\n    rep  stosb\t\t\t\t; Draw the first horizontal line.\r\n    ; Prepare to draw the first vertical line:\r\n    mov  dx, bx\r\n\tdec  di\r\nFirstVert:\r\n    mov  byte [es:di], al\t; Put pixel on screen with appropriate colour.\r\n    add  di, 320\t\t\t; Move one step down in the y-direction.\r\n    dec  bx\t\t\t\t\t; One pixel completed.\r\n    jnz  FirstVert\t\t\t; Are we done yet?\r\n    ; Prepare to draw the second horizontal line:\r\n\tsub  di, 320\r\n    mov  cx, bp\t\t\t\t; Update CX with number of bytes per line.\r\n    std\t\t\t\t\t\t; Set the direction flag to make the stos and movs instructions go backwards.\r\n    rep  stosb\t\t\t\t; Draw the second horizontal line.\r\n    inc  di\t\t\t\t\t; Move backwards one step again to end up in the beginning of the last line...\r\n    ; Finally, last line: the second verical line which ends at the original X- and Y-coordinates.\r\nSecondVert:\r\n    mov  byte [es:di], al\t; Plot the pixel.\r\n    sub  di, 320\t\t\t; Go upwards one step in the y-direction.\r\n    dec  dx\t\t\t\t\t; One pixel completed.\r\n    jnz  SecondVert\t\t\t; If line is not completed, plot one more pixel.\r\n\t\r\n    pop  dx\r\n    pop  bp\r\n    \n    cld\r\n    ret\r\n; END of DrawRect\r\n\n\n;---------------------------------------------------------------------------------------------------------\r\n; SetPalet -- Sets the palette for the 13h graphics mode.\r\n; - Input: \r\n;   SI: Address to palette data (simple linear byte sequence for all 768 values).\r\n; - Output: Palette data starting at hardware port 3C9h.\r\n;---------------------------------------------------------------------------------------------------------\nSetPalet:\r\n\tpush cx\r\n\tpush dx\n    push ax\r\n\t\r\n\tmov  dx, 03C8h\t\t\t; The byte at 03C8h specifies which colour value (0 to 255) we are going to define.\r\n\txor  al, al\t\t\t\t; Start with colour value 0.\r\n\tout  dx, al\t\t\t\t; Set it.\r\n\tinc  dx\t\t\t\t\t; Increase the I/O addres to 03C8h, where the actual palette data starts.\r\n\tmov  cx, 3*256\t\t\t; The number of bytes is three for each of the 256 colour values (= 768).\r\n\trep  outsb\t\t\t\t; Copy the entire palette data pointed to by SI.\r\n\t\r\n\tpop  dx\r\n\tpop  cx\r\n\tpop  ax\r\n\t\r\n\tret\r\n;END of SetPalette\n\n\n;---------------------------------------------------------------------------------------------------------\r\n; ClearScreen -- Fills the entire screen with the colour 00h. Made for the 13h graphics mode.\r\n; - Input: None.\r\n; - Output: 00h bytes to [ES:DI].\r\n;---------------------------------------------------------------------------------------------------------\nClearScreen:\npush ax\npush di\npush cx\n\nmov  eax, 00000000h\nmov  di, 0000h\nmov  cx, 320*200/4\t\t\t; Copy the number of words to move to CX (which will be counted down by rep movsw).\r\nrep  stosd\n\npop  cx\npop  di\npop  ax\n\r\nret\n;END of ClearScreen\n","markerStore":{"version":2,"nextMarkerId":273,"markersById":{"0":{"range":{"start":{"row":0,"column":0},"end":{"row":0,"column":0}},"properties":{"type":"selection","editorId":4},"reversed":false,"tailed":false,"valid":true,"invalidate":"never"}}},"history":{"version":2,"nextCheckpointId":1,"undoStack":[],"redoStack":[]},"encoding":"utf8","filePath":"/Users/joegesualdo/Downloads/tetra/ttrfun.asm","modifiedWhenLastPersisted":false,"digestWhenLastPersisted":"57b2c6732552c86fc680d299598315f071b36873","deserializer":"TextBuffer","version":2},{"text":"palette\t\t\tdb\t00, 00, 00\t; Colours 0-63: Gray-scale (black becoming whiter).\r\n\t\t\tdb\t01, 01, 01\r\n\t\t\tdb\t02, 02, 02\r\n\t\t\tdb\t03, 03, 03\r\n\t\t\tdb\t04, 04, 04\r\n\t\t\tdb\t05, 05, 05\r\n\t\t\tdb\t06, 06, 06\r\n\t\t\tdb\t07, 07, 07\r\n\t\t\tdb\t08, 08, 08\r\n\t\t\tdb\t09, 09, 09\r\n\t\t\tdb\t10, 