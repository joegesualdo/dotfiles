                            	for key in keys(s:glbs) | if exists('+'.key)
                            		sil! exe 'let &'.key.' = s:glb_'.key
                            	en | endfo
                            	if exists('s:glb_acd') | let &acd = s:glb_acd | en
                            	let g:ctrlp_lines = []
                            	if s:winres[1] >= &lines && s:winres[2] == winnr('$')
                            		exe s:winres[0].s:winres[0]
                            	en
