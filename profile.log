    1              0.000003 fu! ctrlp#files()
                            	let cafile = ctrlp#utils#cachefile()
                            	if g:ctrlp_newcache || !filereadable(cafile) || s:nocache(cafile)
                            		let [lscmd, s:initcwd, g:ctrlp_allfiles] = [s:lsCmd(), s:dyncwd, []]
